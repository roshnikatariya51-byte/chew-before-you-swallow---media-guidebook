<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CHEW BEFORE YOU SWALLOW</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Jost:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Reenie+Beanie&display=swap" rel="stylesheet">
<style>
:root {
  --orange: #FF4000;
  --blue:   #0A1045;
  --lace:   #FFF3E1;
  --white:  #ffffff;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--lace);
  color: var(--blue);
  font-family: 'Jost', sans-serif;
  overflow-x: hidden;
  cursor: crosshair;
}
body::after {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 9999;
}

/* ── COVER ── */
.cover {
min-height: 100vh;
background: var(–blue);
display: flex; flex-direction: column; justify-content: center;
padding: 3.5rem 2rem 5.5rem;
position: relative; overflow: hidden;
}
.cover-dots {
position: absolute; inset: 0;
background-image: radial-gradient(circle, rgba(255,64,0,0.15) 1px, transparent 1px);
background-size: 28px 28px;
pointer-events: none;
}
.cover-label {
font-family: ‘Jost’, sans-serif;
font-size: 0.6rem; letter-spacing: 0.35em;
color: rgba(255,243,225,0.4);
text-transform: uppercase;
margin-bottom: 1.5rem;
position: relative; z-index: 2;
}
.cover-h1 {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(2.6rem, 10vw, 6.5rem);
font-weight: 900;
line-height: 1.0;
color: var(–lace);
position: relative; z-index: 2;
letter-spacing: -0.02em;
}
.cover-h1 .orange { color: var(–orange); display: block; }
.cover-sub {
margin-top: 2rem;
font-family: ‘Reenie Beanie’, cursive;
font-size: 1.6rem;
color: rgba(255,243,225,0.55);
position: relative; z-index: 2;
line-height: 1.4;
max-width: 340px;
}
.cover-badge {
position: absolute; bottom: 5rem; right: 2rem;
width: 82px; height: 82px;
background: var(–orange); border-radius: 50%;
border: 3px solid var(–lace);
display: flex; align-items: center; justify-content: center; text-align: center;
animation: rot 14s linear infinite; z-index: 3;
}
.cover-badge span {
font-family: ‘Jost’, sans-serif; font-size: 0.42rem;
font-weight: 700; color: var(–lace);
text-transform: uppercase; letter-spacing: 0.08em; line-height: 1.6;
}
@keyframes rot { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.cover-ticker {
position: absolute; bottom: 0; left: 0; right: 0;
background: var(–orange); overflow: hidden; height: 40px;
display: flex; align-items: center;
}
.ticker-inner {
display: flex; gap: 2rem; white-space: nowrap;
animation: tick 22s linear infinite;
font-family: ‘Unbounded’, sans-serif; font-size: 0.65rem; font-weight: 700;
color: var(–lace); letter-spacing: 0.08em; padding: 0 1rem;
text-transform: uppercase;
}
@keyframes tick { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.ticker-inner .sep { opacity: 0.35; }

/* ── SHARED ── */
.sec {
padding: 4.5rem 2rem 5rem;
position: relative; overflow: hidden;
border-top: 3px solid var(–blue);
}
.sec–blue   { background: var(–blue);   color: var(–lace); border-color: var(–orange); }
.sec–lace   { background: var(–lace);   color: var(–blue); }
.sec–orange { background: var(–orange); color: var(–lace); border-color: var(–blue); }

.sec-num {
position: absolute; top: 1rem; right: 1.5rem;
font-family: ‘Unbounded’, sans-serif; font-weight: 900;
font-size: 7rem; line-height: 1;
opacity: 0.06; pointer-events: none; user-select: none;
}

.tag {
display: inline-block;
font-family: ‘Jost’, sans-serif;
font-size: 0.58rem; letter-spacing: 0.28em; text-transform: uppercase;
padding: 4px 12px; margin-bottom: 1.2rem;
font-weight: 600;
}
.sec–blue   .tag { background: var(–orange); color: var(–lace); }
.sec–lace   .tag { background: var(–blue);   color: var(–lace); }
.sec–orange .tag { background: var(–blue);   color: var(–lace); }

.sec-h {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(1.8rem, 7vw, 3.8rem);
font-weight: 900;
line-height: 1.05; letter-spacing: -0.02em;
margin-bottom: 2rem;
}
.sec-h .hl { padding: 2px 6px; display: inline; }
.sec–blue   .sec-h .hl { background: var(–orange); color: var(–lace); }
.sec–lace   .sec-h .hl { background: var(–orange); color: var(–lace); }
.sec–orange .sec-h .hl { background: var(–blue);   color: var(–lace); }

.body-txt {
font-family: ‘Jost’, sans-serif;
font-size: 0.95rem; line-height: 1.85; max-width: 580px;
font-weight: 400;
}

.pull {
font-family: ‘Reenie Beanie’, cursive;
font-size: clamp(1.6rem, 5vw, 2.4rem);
line-height: 1.35;
margin: 2.5rem 0;
padding-left: 1.2rem;
border-left: 5px solid;
}
.sec–blue   .pull { color: var(–orange); border-color: var(–orange); }
.sec–lace   .pull { color: var(–blue);   border-color: var(–orange); }
.sec–orange .pull { color: var(–lace);   border-color: var(–blue); }

.pull-attr {
display: block;
font-family: ‘Jost’, sans-serif;
font-size: 0.65rem; letter-spacing: 0.12em;
text-transform: uppercase; margin-top: 0.4rem;
opacity: 0.55;
}

/* tip */
.tip {
margin: 2rem 0; padding: 1.4rem;
border: 2px solid; position: relative;
font-family: ‘Jost’, sans-serif;
}
.sec–blue   .tip { background: rgba(255,64,0,0.08);   border-color: var(–orange); }
.sec–lace   .tip { background: rgba(10,16,69,0.05);   border-color: var(–blue); }
.sec–orange .tip { background: rgba(255,243,225,0.12); border-color: var(–lace); }
.tip::before {
content: ‘wait, actually —’;
font-family: ‘Reenie Beanie’, cursive;
font-size: 1.1rem;
position: absolute; top: -14px; left: 12px;
padding: 0 8px;
}
.sec–blue   .tip::before { background: var(–blue);   color: var(–orange); }
.sec–lace   .tip::before { background: var(–lace);   color: var(–orange); }
.sec–orange .tip::before { background: var(–orange); color: var(–lace); }
.tip p { font-size: 0.88rem; line-height: 1.8; }

/* rip */
.rip { height: 36px; }
.rip–bl { background: var(–blue);   clip-path: polygon(0 0,3% 55%,7% 15%,12% 70%,18% 25%,23% 75%,29% 20%,35% 68%,40% 18%,46% 72%,52% 22%,58% 68%,64% 25%,70% 60%,76% 18%,82% 72%,88% 22%,94% 66%,100% 28%,100% 100%,0 100%); }
.rip–lc { background: var(–lace);  clip-path: polygon(0 38%,3% 88%,7% 42%,12% 90%,18% 35%,23% 85%,29% 40%,35% 82%,40% 28%,46% 84%,52% 32%,58% 78%,64% 25%,70% 72%,76% 36%,82% 80%,88% 28%,94% 74%,100% 20%,100% 0,0 0); }
.rip–or { background: var(–orange); clip-path: polygon(0 0,3% 55%,7% 15%,12% 70%,18% 25%,23% 75%,29% 20%,35% 68%,40% 18%,46% 72%,52% 22%,58% 68%,64% 25%,70% 60%,76% 18%,82% 72%,88% 22%,94% 66%,100% 28%,100% 100%,0 100%); }

/* ── TOPIC 1 — THREE FLAVOURS ── */
.flavours {
display: flex; flex-direction: column; gap: 0;
margin: 2rem 0;
border: 2px solid var(–orange);
}
.flavour-item {
padding: 1.3rem 1.4rem;
border-bottom: 2px solid rgba(255,64,0,0.2);
position: relative;
}
.flavour-item:last-child { border-bottom: none; }
.flavour-name {
font-family: ‘Unbounded’, sans-serif;
font-size: 1rem; font-weight: 700;
letter-spacing: 0.02em; margin-bottom: 0.4rem;
}
.f-mis  .flavour-name { color: var(–orange); }
.f-dis  .flavour-name { color: #ff8c00; }
.f-mal  .flavour-name { color: #ffbf80; }
.flavour-def {
font-size: 0.88rem; line-height: 1.7;
margin-bottom: 0.4rem;
}
.flavour-eg {
font-family: ‘Reenie Beanie’, cursive;
font-size: 1.1rem; opacity: 0.6;
}

/* ── TOPIC 2 — NEWS GRID ── */
.news-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 0; margin: 2rem 0;
border: 2px solid var(–blue);
}
.news-card {
padding: 1.2rem;
border-right: 2px solid rgba(10,16,69,0.15);
border-bottom: 2px solid rgba(10,16,69,0.15);
}
.news-card:nth-child(even) { border-right: none; }
.news-card:nth-child(3), .news-card:nth-child(4) { border-bottom: none; }
.news-card-num {
font-family: ‘Unbounded’, sans-serif;
font-size: 1.8rem; font-weight: 900;
color: var(–orange); line-height: 1; margin-bottom: 0.5rem;
}
.news-card-name {
font-family: ‘Unbounded’, sans-serif;
font-size: 0.65rem; font-weight: 700;
letter-spacing: 0.05em; margin-bottom: 0.5rem;
color: var(–blue);
}
.news-card p { font-size: 0.8rem; line-height: 1.7; color: rgba(10,16,69,0.75); }

/* ── TOPIC 3 — TOOLKIT ── */
.toolkit {
display: flex; flex-direction: column;
gap: 0; margin: 2rem 0;
}
.tool-item {
padding: 1.2rem 0;
border-bottom: 1px dashed rgba(255,243,225,0.15);
display: grid; grid-template-columns: 2.5rem 1fr;
gap: 1rem; align-items: start;
}
.tool-item:last-child { border-bottom: none; }
.tool-n {
font-family: ‘Unbounded’, sans-serif;
font-size: 1.4rem; font-weight: 900;
color: var(–orange); line-height: 1.1;
}
.tool-body {}
.tool-name {
font-family: ‘Unbounded’, sans-serif;
font-size: 0.75rem; font-weight: 700;
letter-spacing: 0.03em; margin-bottom: 0.3rem;
color: var(–lace);
}
.tool-def { font-size: 0.82rem; line-height: 1.65; color: rgba(255,243,225,0.75); margin-bottom: 0.3rem; }
.tool-eg  { font-family: ‘Reenie Beanie’, cursive; font-size: 1.05rem; color: var(–orange); }

/* ── TOPIC 4 — SICK ── */
.sick-grid {
display: grid; grid-template-columns: 1fr 1fr;
gap: 1rem; margin: 2rem 0;
}
.sick-card {
padding: 1.2rem;
border: 2px solid rgba(255,64,0,0.25);
background: rgba(255,64,0,0.05);
}
.sick-letter {
font-family: ‘Unbounded’, sans-serif;
font-size: 2.8rem; font-weight: 900;
color: var(–orange); line-height: 1; margin-bottom: 0.4rem;
}
.sick-name {
font-family: ‘Unbounded’, sans-serif;
font-size: 0.65rem; font-weight: 700;
letter-spacing: 0.05em; margin-bottom: 0.4rem;
}
.sick-desc { font-size: 0.8rem; line-height: 1.7; opacity: 0.8; }

.stat-big {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(3rem, 12vw, 6rem);
font-weight: 900; color: var(–orange);
line-height: 1; margin-bottom: 0.3rem;
}
.stat-label { font-size: 0.82rem; line-height: 1.7; opacity: 0.75; max-width: 400px; margin-bottom: 2rem; }

/* ══════════════════════════
THE REACTION LAB
══════════════════════════ */
.lab-wrap {
margin-top: 2.5rem;
border: 3px solid var(–lace);
overflow: hidden;
}
.lab-header {
background: var(–lace); padding: 1rem 1.4rem;
display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
}
.lab-header h3 {
font-family: ‘Unbounded’, sans-serif;
font-size: 1.4rem; font-weight: 900; color: var(–blue);
letter-spacing: -0.01em;
}
.lab-counter {
font-family: ‘Reenie Beanie’, cursive;
font-size: 1.4rem; color: var(–orange);
}
.lab-progress { height: 5px; background: rgba(255,243,225,0.1); }
.lab-progress-fill { height: 100%; background: var(–orange); transition: width 0.4s ease; width: 0%; }
.lab-instr {
background: rgba(255,243,225,0.05);
padding: 0.9rem 1.4rem;
font-family: ‘Jost’, sans-serif;
font-size: 0.72rem; line-height: 1.75; color: rgba(255,243,225,0.6);
border-bottom: 1px solid rgba(255,243,225,0.1);
}
.lab-cards { padding: 1.2rem; display: flex; flex-direction: column; gap: 1.2rem; }

.hl-card {
background: rgba(255,243,225,0.04);
border: 2px solid rgba(255,243,225,0.1);
border-radius: 4px; overflow: hidden;
transition: border-color 0.2s;
}
.hl-card.answered { pointer-events: none; }
.hl-card.revealed-correct { border-color: var(–orange) !important; background: rgba(255,64,0,0.08); }
.hl-card.revealed-wrong   { border-color: rgba(255,243,225,0.3) !important; }

.hl-tag {
padding: 0.3rem 0.8rem;
font-family: ‘Jost’, sans-serif;
font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase;
font-weight: 600; color: rgba(255,243,225,0.4);
border-bottom: 1px solid rgba(255,243,225,0.08);
}
.hl-text {
padding: 1rem 1.2rem 0.8rem;
font-family: ‘Jost’, sans-serif;
font-size: 0.9rem; line-height: 1.65;
color: var(–lace); font-style: italic;
}
.hl-question {
padding: 0 1.2rem 0.5rem;
font-family: ‘Jost’, sans-serif;
font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase;
color: rgba(255,243,225,0.4); font-weight: 600;
}
.hl-emotions {
display: flex; flex-wrap: wrap; gap: 0.5rem;
padding: 0.5rem 1.2rem 1rem;
}
.emo-btn {
background: transparent;
border: 2px solid rgba(255,243,225,0.2);
color: rgba(255,243,225,0.7);
padding: 0.4rem 0.8rem;
font-family: ‘Jost’, sans-serif; font-size: 0.7rem; font-weight: 600;
cursor: pointer; letter-spacing: 0.06em;
transition: all 0.15s; border-radius: 2px;
text-transform: uppercase;
}
.emo-btn:hover { border-color: var(–orange); color: var(–orange); }
.emo-btn.picked-right { background: var(–orange); border-color: var(–orange); color: var(–lace); }
.emo-btn.picked-wrong { background: rgba(255,243,225,0.1); border-color: rgba(255,243,225,0.3); color: rgba(255,243,225,0.5); }
.emo-btn.show-right   { border-color: var(–orange); color: var(–orange); }

.hl-reveal {
display: none;
padding: 0.8rem 1.2rem 1rem;
border-top: 1px solid rgba(255,243,225,0.08);
}
.hl-card.answered .hl-reveal { display: block; }
.reveal-result {
font-family: ‘Unbounded’, sans-serif;
font-size: 0.7rem; font-weight: 700;
letter-spacing: 0.05em; margin-bottom: 0.4rem;
}
.reveal-result.right { color: var(–orange); }
.reveal-result.wrong { color: rgba(255,243,225,0.5); }
.reveal-explain {
font-family: ‘Reenie Beanie’, cursive;
font-size: 1.15rem; line-height: 1.6;
color: rgba(255,243,225,0.65);
}

/* ── FOOTER ── */
.footer {
background: var(–blue); color: var(–lace);
padding: 3.5rem 2rem 4rem;
position: relative; overflow: hidden;
border-top: 3px solid var(–orange);
}
.footer::before {
content: ‘chew.’;
font-family: ‘Unbounded’, sans-serif; font-weight: 900;
font-size: 8rem; position: absolute; right: -1rem; bottom: -1.5rem;
opacity: 0.04; line-height: 1; color: var(–orange); pointer-events: none;
}
.footer-h {
font-family: ‘Unbounded’, sans-serif;
font-size: clamp(1.4rem, 5vw, 2.2rem);
font-weight: 900; letter-spacing: -0.01em;
color: var(–orange); margin-bottom: 0.8rem; line-height: 1.2;
}
.footer-txt { font-size: 0.88rem; line-height: 1.9; opacity: 0.75; max-width: 460px; }
.footer-refs {
margin-top: 2rem; padding-top: 1.5rem;
border-top: 1px solid rgba(255,243,225,0.1);
font-size: 0.62rem; line-height: 1.9;
opacity: 0.4; letter-spacing: 0.05em;
}
.footer-refs strong { opacity: 0.7; letter-spacing: 0.12em; font-size: 0.58rem; text-transform: uppercase; }
.footer-bar {
margin-top: 1.5rem; padding-top: 1rem;
border-top: 1px solid rgba(255,243,225,0.08);
display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
font-size: 0.55rem; opacity: 0.3; letter-spacing: 0.18em; text-transform: uppercase;
}

/* fade */
.fade { opacity: 0; transform: translateY(22px); transition: opacity 0.55s ease, transform 0.55s ease; }
.fade.vis { opacity: 1; transform: translateY(0); }
</style>

</head>
