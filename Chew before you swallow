    <span>Think first. Share second.</span>
  </div>
</div>

<script>
// ══ REACTION LAB DATA ══
const HEADLINES = [
  {
    type: 'NEWS — OBVIOUS',
    text: '"THEY ARE COMING FOR YOUR CHILDREN"',
    emotions: ['FEAR','ANGER','PRIDE','CURIOSITY'],
    correct: 'FEAR',
    explain: "Vague threat. No specifics. No named source. Pure Fear Appeal — designed to make you share before you think. The vaguer the threat, the wider the fear spreads."
  },
  {
    type: 'INFLUENCER — OBVIOUS',
    text: '"This is literally the best trip of my life 🌴 link in bio to book yours (ad)"',
    emotions: ['ENVY','FEAR','ANGER','PRIDE'],
    correct: 'ENVY',
    explain: "You don't feel happy for them. You feel behind. That gap between their highlight reel and your Tuesday is the product they're actually selling — not the trip."
  },
  {
    type: 'ADVERTISING — SUBTLE',
    text: '"Dermatologists don\'t want you to know about this ₹299 moisturiser"',
    emotions: ['CURIOSITY','OUTRAGE','FEAR','PRIDE'],
    correct: 'OUTRAGE',
    explain: "Positions an entire profession as your enemy so clicking feels like rebellion. Outrage + Curiosity combo — one makes you angry, the other makes you tap. Classic."
  },
  {
    type: 'SOCIAL MEDIA — SUBTLE',
    text: '"She quit her corporate job, moved to Goa, and never looked back 🌿"',
    emotions: ['INSPIRATION','SHAME','ANGER','FEAR'],
    correct: 'SHAME',
    explain: "Disguised as inspiration. Actually triggers shame — your ordinary life suddenly feels like a failure. The algorithm serves this to people it knows are burnt out. That's not a coincidence."
  },
  {
    type: 'NEWS — MIX',
    text: '"Local teacher saves 12 kids from flood — government takes all the credit"',
    emotions: ['PRIDE','ANGER','FEAR','SADNESS'],
    correct: 'PRIDE',
    explain: "Two-step emotional hit: PRIDE first (feel good about the hero), then ANGER (feel furious at the system). You're more likely to share content that makes you feel two strong emotions back to back. The most shareable combo."
  }
];

let labDone = 0;

function initLab() {
  labDone = 0;
  document.getElementById('labDone').textContent = '0';
  document.getElementById('labFill').style.width = '0%';
  const container = document.getElementById('labCards');
  container.innerHTML = '';
  HEADLINES.forEach((h, i) => container.appendChild(buildCard(h, i)));
}

function buildCard(h, idx) {
  const card = document.createElement('div');
  card.className = 'hl-card'; card.id = 'hlcard-' + idx;
  const btns = h.emotions.map((e, ei) =>
    `<button class="emo-btn" onclick="pickEmotion(${idx},'${e}')">${e}</button>`
  ).join('');
  card.innerHTML = `
    <div class="hl-tag">${h.type}</div>
    <div class="hl-text">${h.text}</div>
    <div class="hl-question">what emotion was this designed to trigger?</div>
    <div class="hl-emotions" id="emo-${idx}">${btns}</div>
    <div class="hl-reveal" id="reveal-${idx}">
      <div class="reveal-result" id="result-${idx}"></div>
      <div class="reveal-explain">${h.explain}</div>
    </div>
  `;
  return card;
}

function pickEmotion(idx, picked) {
  const h = HEADLINES[idx];
  const card = document.getElementById('hlcard-' + idx);
  if (card.classList.contains('answered')) return;
  card.classList.add('answered');

  const correct = picked === h.correct;
  const btns = document.querySelectorAll(`#emo-${idx} .emo-btn`);
  btns.forEach(btn => {
    if (btn.textContent === picked && correct)  btn.classList.add('picked-right');
    if (btn.textContent === picked && !correct) btn.classList.add('picked-wrong');
    if (btn.textContent === h.correct && !correct) btn.classList.add('show-right');
  });

  const resultEl = document.getElementById('result-' + idx);
  if (correct) {
    card.classList.add('revealed-correct');
    resultEl.textContent = '✓ yes — ' + h.correct;
    resultEl.className = 'reveal-result right';
  } else {
    card.classList.add('revealed-wrong');
    resultEl.textContent = '✕ it was ' + h.correct;
    resultEl.className = 'reveal-result wrong';
  }

  labDone++;
  document.getElementById('labDone').textContent = labDone;
  document.getElementById('labFill').style.width = (labDone / HEADLINES.length * 100) + '%';
}

initLab();

// scroll fade
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); });
}, { threshold: 0.07 });
document.querySelectorAll('.fade').forEach(el => obs.observe(el));
</script>

